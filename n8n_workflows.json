          {
            "node": "Push to public.leads",
            "index": 0
          }
        ]
      ]
    },
    "LinkedIn Generator Webhook": {
      "main": [
        [
          {
            "node": "LinkedIn Content Builder",
            "index": 0
          }
        ]
      ]
    },
    "LinkedIn Content Builder": {
      "main": [
        [
          {
            "node": "Publish UGC Post",
            "index": 0
          }
        ]
      ]
    },
    "Google Scholar Webhook": {
      "main": [
        [
          {
            "node": "Fetch Scholar Papers",
            "index": 0
          }
        ]
      ]
    },
    "Fetch Scholar Papers": {
      "main": [
        [
          {
            "node": "Research Filter",
            "index": 0
          }
        ]
      ]
    },
    "Budget Variance Trigger": {
      "main": [
        [
          {
            "node": "Query Local Ledger",
            "index": 0
          }
        ]
      ]
    },
    "Query Local Ledger": {
      "main": [
        [
          {
            "node": "Check Budget Limit",
            "index": 0
          }
        ]
      ]
    },
    "Check Budget Limit": {
      "main": [
        [
          {
            "node": "Send WhatsApp Variance Alert",
            "index": 0
          }
        ]
      ]
    }
  }
}
